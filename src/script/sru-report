#! /bin/bash
# Wrapper around the sru-report tool from ubuntu-archive-tools.
# Evolved from the historical crontab entry, dropping the `git pull`, the proxy
# override (the charm injects proxy configuration via systemd), the run lock
# and the run timeout (the oneshot service serialises runs and bounds them via
# TimeoutStartSec), while keeping the C locale.
set -e

SRU_REPORT_SCRIPT="/usr/local/src/ubuntu-archive-tools/sru-report"
# Allow to specify the destination externally
outputdir=${OUTPUTDIR:-"$HOME/public_html/pending-sru"}
destination="$outputdir/pending-sru.html"

mkdir -p "$outputdir"

# sru-report prints the HTML report to stdout and writes sru_report.yaml into
# the current directory, so run from the output directory to collect both.
cd "$outputdir"

# LC_ALL=C keeps the generated HTML stable regardless of host locale.
LC_ALL=C "$SRU_REPORT_SCRIPT" > "${destination}.new"

# If we got this far, all went well, so rename
mv "${destination}.new" "$destination"
